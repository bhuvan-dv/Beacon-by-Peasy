# Beacon runs against a local Ollama instance — no API key required.
# These are optional overrides; the defaults below match a standard install.

# Where Ollama is listening.
OLLAMA_BASE_URL=http://localhost:11434

# Which local model generates the reorder rationales.
# qwen3:8b is a general instruct model that writes natural, founder-facing prose.
OLLAMA_MODEL=qwen3:8b
